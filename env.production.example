MAIL_PORT=587
MAIL_USER=
MAIL_PASS=
MAIL_FROM=

JWT_SECRET=change_me_to_a_long_random_string_in_production

# Tenant setup link base URL (tenant-web)
TENANT_SETUP_BASE_URL=https://darital-arenda.uz

# Tenant Telegram bot
TELEGRAM_ENABLE=false
TELEGRAM_BOT_TOKEN=
