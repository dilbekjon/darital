# Admin Telegram bot (separate bot from tenant bot)
ADMIN_TELEGRAM_ENABLE=false
ADMIN_TELEGRAM_BOT_TOKEN=
ADMIN_TELEGRAM_WEBAPP_URL=https://admin.darital-arenda.uz

# SMS (Eskiz.uz)
SMS_PROVIDER=devsms
DEVSMS_TOKEN=
DEVSMS_FROM=4546
# If SMS provider requires pre-approved templates, configure these (use {{CODE}} placeholder):
# SMS_TENANT_OTP_TEMPLATE=
# SMS_TENANT_RESET_TEMPLATE=

# Legacy Eskiz fallback
ESKIZ_EMAIL=
ESKIZ_PASSWORD=
ESKIZ_FROM=4546

NODE_ENV=production
PORT=3001

# Backup settings
# BACKUP_BASE_DIR=/opt/darital-backups
# BACKUP_RETENTION_DAYS=14
# Optional off-site backup via rclone
# BACKUP_RCLONE_REMOTE=myremote:darital-backups
# If your cron runs as a different user (e.g. root), point to the correct config:
# BACKUP_RCLONE_CONFIG=/home/darital/.config/rclone/rclone.conf
# Optional Telegram alerts for backup success/failure
# Uses TELEGRAM_BOT_TOKEN and TELEGRAM_ADMIN_CHAT_ID by default
# BACKUP_TELEGRAM_BOT_TOKEN=
# BACKUP_TELEGRAM_CHAT_ID=
